SYSTEM_PROMPT = """你是严谨的中文人物关系抽取助手。
请从用户原文中提取全部明确表达的人物关系，并遵守以下规则：
1. 只提取原文明示的关系，不推测、不补充。
2. 一句话可以包含多条关系，必须完整处理“但是、然而、并且”等结构。
3. 否定事实必须保留：“不喜欢”“不信任”“非朋友”等不得转成肯定关系。
4. 人物名称必须原样来自用户文本；没有人物关系时 relations 返回空数组。
5. 规范关系名：喜欢/暗恋/爱上→爱慕；朋友/好友→朋友；讨厌/厌恶→讨厌；
   帮助/协助→帮助；信任/相信→信任；同学→同学；同事→同事；
   上司/领导→上下级；父亲/母亲/兄弟/姐妹→亲属。
6. 只输出合法 JSON，不要 Markdown、代码围栏或解释。
输出结构：{"relations":[{"source":"人物","relation":"关系","target":"人物"}]}
"""

RELATION_TOOL = {
    "type": "function",
    "function": {
        "name": "save_person_relations",
        "description": "保存用户原文中明确出现的全部人物关系",
        "parameters": {
            "type": "object",
            "properties": {
                "relations": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "source": {"type": "string"},
                            "relation": {"type": "string"},
                            "target": {"type": "string"},
                        },
                        "required": ["source", "relation", "target"],
                        "additionalProperties": False,
                    },
                }
            },
            "required": ["relations"],
            "additionalProperties": False,
        },
    },
}


class RelationAnalysisError(RuntimeError):
    """可安全展示给用户的关系分析错误。"""


def parse_relation_json(text: str) -> RelationResult:
    """解析模型 JSON，兼容 Markdown 围栏及顶层数组。"""
    cleaned = text.strip()
    fenced = re.fullmatch(r"```(?:json)?\s*(.*?)\s*```", cleaned, flags=re.S | re.I)
    if fenced:
        cleaned = fenced.group(1).strip()
    try:
        raw = json.loads(cleaned)
    except json.JSONDecodeError as exc:
        raise RelationAnalysisError("模型没有返回合法 JSON，请重试。") from exc
    if isinstance(raw, list):
        raw = {"relations": raw}
    try:
        return RelationResult.model_validate(raw)
    except ValidationError as exc:
        raise RelationAnalysisError("模型返回的关系字段不完整或类型错误，请重试。") from exc


class RelationAgent:
    """人物关系智能体：优先 JSON Mode，失败后回退 Tool Calling。"""

    def __init__(self, llm: LLMClient | None = None):
        self.llm = llm or LLMClient(timeout=60.0)
        self.last_mode: str | None = None

    @property
    def is_configured(self) -> bool:
        return bool(
            self.llm.api_key
            and "your" not in self.llm.api_key.lower()
            and self.llm.base_url
            and self.llm.model
        )

    @staticmethod
    def _validate_source_names(result: RelationResult, text: str) -> RelationResult:
        """拒绝模型凭空生成不在原文中的人物，并移除完全重复关系。"""
        unique = []
        seen = set()
        for relation in result.relations:
            if relation.source not in text or relation.target not in text:
                raise RelationAnalysisError("模型返回了原文中不存在的人物，请重试。")
            key = (relation.source, relation.relation, relation.target)
            if key not in seen:
                seen.add(key)
                unique.append(relation)
        return RelationResult(relations=unique)

    def analyze(self, text: str) -> RelationResult:
        text = text.strip()
        if not text:
            raise RelationAnalysisError("请输入需要分析的文本。")
        if not self.is_configured:
            raise RelationAnalysisError(
                "大模型尚未配置。请复制 .env.example 为 .env，并填写 LLM 配置。"
            )
        messages = [
            {"role": "system", "content": SYSTEM_PROMPT},
            {"role": "user", "content": text},
        ]
        json_error: Exception | None = None
        try:
            response = self.llm.client.chat.completions.create(
                model=self.llm.model,
                messages=messages,
                response_format={"type": "json_object"},
                temperature=0,
            )
            self.last_mode = "JSON Mode"
            result = parse_relation_json(response.choices[0].message.content or "")
            return self._validate_source_names(result, text)
        except Exception as exc:
            json_error = exc
        try:
            response = self.llm.client.chat.completions.create(
                model=self.llm.model,
                messages=messages,
                tools=[RELATION_TOOL],
                tool_choice={
                    "type": "function",
                    "function": {"name": "save_person_relations"},
                },
                temperature=0,
            )
            message = response.choices[0].message
            if not message.tool_calls:
                raise RelationAnalysisError("模型未返回关系提取工具调用。")
            arguments = json.loads(message.tool_calls[0].function.arguments)
            self.last_mode = "Tool Calling（JSON Mode 回退）"
            result = RelationResult.model_validate(arguments)
            return self._validate_source_names(result, text)
        except RelationAnalysisError:
            raise
        except Exception as tool_error:
            reason = f"{type(json_error).__name__} / {type(tool_error).__name__}"
            raise RelationAnalysisError(
                f"模型请求失败（{reason}）。请检查 API 地址、模型名称和网络连接。"
            ) from tool_error

"""人物关系有向图渲染。"""

import matplotlib.pyplot as plt
import networkx as nx

from src.plot_config import configure_chinese_font
from src.relation_model import PersonRelation


def build_relation_figure(relations: list[PersonRelation]):
    """将人物关系列表渲染为适合 Streamlit 的 Matplotlib 图。"""
    if not relations:
        return None
    graph = nx.MultiDiGraph()
    for relation in relations:
        graph.add_edge(relation.source, relation.target, label=relation.relation)
    configure_chinese_font()
    figure, axis = plt.subplots(figsize=(9, 5))
    position = nx.spring_layout(graph, seed=42, k=1.8)
    nx.draw_networkx_nodes(
        graph, position, node_color="#dceeff", edgecolors="#2878b5",
        node_size=2600, linewidths=1.5, ax=axis
    )
    nx.draw_networkx_labels(graph, position, font_size=11, ax=axis)
    nx.draw_networkx_edges(
        graph, position, edge_color="#666666", arrows=True, arrowsize=22,
        connectionstyle="arc3,rad=0.08", min_source_margin=20,
        min_target_margin=20, ax=axis
    )
    edge_labels = {}
    for source, target in graph.edges():
        labels = [
            data["label"] for data in graph.get_edge_data(source, target).values()
        ]
        edge_labels[(source, target)] = " / ".join(labels)
    nx.draw_networkx_edge_labels(
        graph, position, edge_labels=edge_labels, font_color="#b22222",
        font_size=10, label_pos=0.5, ax=axis
    )
    axis.set_axis_off()
    figure.tight_layout()
    return figure


