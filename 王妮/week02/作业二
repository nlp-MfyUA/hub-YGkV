"""人物关系智能体的离线单元测试。"""

from types import SimpleNamespace

import pytest

from src.relation_agent import RelationAgent, RelationAnalysisError, parse_relation_json


class FakeCompletions:
    def __init__(self, json_content=None, tool_arguments=None, fail_json=False):
        self.json_content = json_content
        self.tool_arguments = tool_arguments
        self.fail_json = fail_json

    def create(self, **kwargs):
        if "response_format" in kwargs:
            if self.fail_json:
                raise RuntimeError("JSON Mode unsupported")
            message = SimpleNamespace(content=self.json_content, tool_calls=None)
        else:
            tool_call = SimpleNamespace(
                function=SimpleNamespace(arguments=self.tool_arguments)
            )
            message = SimpleNamespace(content=None, tool_calls=[tool_call])
        return SimpleNamespace(choices=[SimpleNamespace(message=message)])


class FakeLLM:
    def __init__(self, completions):
        self.api_key = "test-key"
        self.base_url = "https://example.invalid"
        self.model = "test-model"
        self.client = SimpleNamespace(
            chat=SimpleNamespace(completions=completions)
        )


def test_parse_two_relations_from_json_mode():
    result = parse_relation_json(
        """```json
        {"relations":[
          {"source":"小明","relation":"爱慕","target":"小姚"},
          {"source":"小姚","relation":"爱慕","target":"小王"}
        ]}
        ```"""
    )
    assert len(result.relations) == 2
    assert result.relations[1].source == "小姚"


def test_parse_top_level_array_and_empty_array():
    assert parse_relation_json("[]").relations == []
    result = parse_relation_json(
        '[{"source":"小红","relation":"朋友","target":"小丽"}]'
    )
    assert result.relations[0].relation == "朋友"


def test_friends_and_dislike_sample():
    result = parse_relation_json(
        '{"relations":['
        '{"source":"小红","relation":"朋友","target":"小丽"},'
        '{"source":"小丽","relation":"讨厌","target":"小刚"}]}'
    )
    assert [item.relation for item in result.relations] == ["朋友", "讨厌"]


def test_weather_sample_returns_empty_array():
    assert parse_relation_json('{"relations":[]}').relations == []


def test_invalid_json_has_friendly_error():
    with pytest.raises(RelationAnalysisError, match="合法 JSON"):
        parse_relation_json("不是 JSON")


def test_agent_uses_json_mode_for_all_explicit_relations():
    content = (
        '{"relations":['
        '{"source":"张老师","relation":"帮助","target":"李同学"},'
        '{"source":"李同学","relation":"信任","target":"张老师"}]}'
    )
    agent = RelationAgent(FakeLLM(FakeCompletions(json_content=content)))
    result = agent.analyze("张老师帮助了李同学，李同学很信任张老师。")
    assert [item.relation for item in result.relations] == ["帮助", "信任"]
    assert agent.last_mode == "JSON Mode"


def test_agent_falls_back_to_tool_calling():
    arguments = (
        '{"relations":['
        '{"source":"小明","relation":"不喜欢","target":"小王"},'
        '{"source":"小王","relation":"朋友","target":"小明"}]}'
    )
    completions = FakeCompletions(tool_arguments=arguments, fail_json=True)
    agent = RelationAgent(FakeLLM(completions))
    result = agent.analyze("小明不喜欢小王，但是小王把小明当作朋友。")
    assert result.relations[0].relation == "不喜欢"
    assert len(result.relations) == 2
    assert agent.last_mode.startswith("Tool Calling")


def test_agent_rejects_person_not_present_in_source():
    content = (
        '{"relations":['
        '{"source":"小明","relation":"爱慕","target":"不存在的人"}]}'
    )
    arguments = '{"relations":[]}'
    completions = FakeCompletions(
        json_content=content, tool_arguments=arguments
    )
    agent = RelationAgent(FakeLLM(completions))
    result = agent.analyze("小明喜欢小姚。")
    assert result.relations == []
    assert agent.last_mode.startswith("Tool Calling")
